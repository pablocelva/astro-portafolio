---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';


export async function getStaticPaths() {
  const servicios = await getCollection('services');
  return servicios.map(servicio => ({
    params: { id: servicio.data.id },
    props: { servicio }, 
  }));
}

const { servicio } = Astro.props;
const { data } = servicio;

const {
  title,
  description,
  useCases = [],
  tags = [],
  tools = []
} = data;
---

<Layout title={title}>
  <section class="service-page">
    <h1>{title}</h1>
    <p>{description}</p>

    {/* Renderizado seguro: si useCases está vacío, no muestra nada */}
    {useCases.length > 0 && (
      <div class="use-cases">
        <h2>Use Cases</h2>
        <ul>
          {useCases.map((item: string) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    )}

    {/* Opcional: Mostrar herramientas si quieres */}
    {tools.length > 0 && (
      <div class="tools">
        <h2>Herramientas</h2>
        <ul>
          {tools.map((tool: string) => (
            <li>{tool}</li>
          ))}
        </ul>
      </div>
    )}

    {/* Opcional: Mostrar tags si quieres */}
    {tags.length > 0 && (
        <span class="tags">
        {tags.map((tag: string) => (
          <li>{tag}</li>
        ))}
      </span>
    )}
  </section>
</Layout>
