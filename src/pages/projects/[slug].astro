---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from 'astro:content';
import '../../styles/project-page.css';

// 1. Obtener todos los proyectos tipados desde Content Collections

// 2. Generar las rutas estáticas
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project }, // Pasamos el objeto completo tipado
  }));
}

// 3. Obtener los props con tipos seguros
const { project } = Astro.props;
const { data } = project; // 'data' contiene todos los campos definidos en el schema

// Desestructuración segura con valores por defecto (aunque el schema ya los exige)
const { 
  title, 
  description, 
  year, 
  status, 
  tags = [], 
  features = [], 
  images = [], 
  links = { demo: null, frontendRepo: null, backendRepo: null, docs: null }, 
  stack = {} 
} = data;

// Helper para filtrar tecnologías "None" o vacías con tipado explícito
const getValidTechs = (techs: string[]) => {
  return techs.filter((t: string) => t !== "None" && t !== "");
};
---

<Layout title={title}>
  <main class="project-container">
    
    <!-- HEADER -->
    <header class="project-header">
      <h1>{title}</h1>
      <p class="project-description">{description}</p>
      
      <div class="project-meta">
        <span><strong>Año:</strong> {year}</span>
        <span><strong>Estado:</strong> {status}</span>
      </div>

      {tags.length > 0 && (
        <ul class="tags">
          {/* Tipado explícito en el map */}
          {tags.map((tag: string) => <li>{tag}</li>)}
        </ul>
      )}
    </header>

    <!-- ACTION BUTTONS -->
    {(links.demo || links.frontendRepo || links.backendRepo || links.docs) && (
      <section class="project-actions">
        {links.demo && (
          <a href={links.demo} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            Ver Demo
          </a>
        )}
        {links.frontendRepo && (
          <a href={links.frontendRepo} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            Frontend
          </a>
        )}
        {links.backendRepo && (
          <a href={links.backendRepo} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            Backend
          </a>
        )}
        {links.docs && (
          <a href={links.docs} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            Docs
          </a>
        )}
      </section>
    )}

    <!-- GALLERY -->
    {images.length > 0 && (
      <section class="project-gallery">
        <h2>Galería</h2>
        <div class="gallery-grid">
          {images.map((img: string) => (
            <img src={img} alt={`Vista de ${title}`} loading="lazy" />
          ))}
        </div>
      </section>
    )}

    <!-- FEATURES -->
    {features.length > 0 && (
      <section class="project-features">
        <h2>Características Clave</h2>
        <ul>
          {features.map((feature: string) => <li>{feature}</li>)}
        </ul>
      </section>
    )}

    <!-- STACK -->
    <section class="project-stack">
      <h2>Stack Tecnológico</h2>
      <div class="stack-grid">
        {Object.entries(stack).map(([category, technologies]) => {
          // technologies es string[] gracias al schema z.record(z.array(z.string()))
          const validTechs = getValidTechs(technologies);
          
          if (validTechs.length === 0) return null;

          return (
            <div class="stack-category">
              <h3>{category.charAt(0).toUpperCase() + category.slice(1)}</h3>
              <ul>
                {validTechs.map((tech: string) => <li>{tech}</li>)}
              </ul>
            </div>
          );
        })}
      </div>
    </section>

  </main>
</Layout>